# ─── ShiftCall Frontend ────────────────────────────────────────────
# Rename this file to .env (or .env.local) and fill in the values.

# ─── 1. Supabase (optional, recommended) ──────────────────────────
# Create a free project at https://supabase.com → Settings → API
# If left blank, the app runs in LOCAL DEMO MODE (auth + history live
# only in your browser).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── 2. Optional fallback API keys ────────────────────────────────
# Per-user keys entered through the Onboarding wizard always take
# precedence. These env vars are only used as a fallback for local dev
# (e.g. so a single dev doesn't have to type keys after every cache
# clear). For a real workspace, leave these empty and use the wizard.
VITE_VAPI_PUBLIC_KEY=
VITE_DEEPGRAM_API_KEY=
