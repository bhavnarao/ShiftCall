# --- Required ---
XAI_API_KEY=xai-...
XAI_MODEL=grok-2-latest

# --- Trial mode (optional, only needed if you want to offer free trial calls) ---
# Vapi public key is browser-safe; Deepgram master key stays server-side and is
# used to mint short-lived scoped tokens per trial session.
VAPI_TRIAL_PUBLIC_KEY=
DEEPGRAM_TRIAL_KEY=

# --- CORS (production only) ---
# Comma-separated list of allowed frontend origins.
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app

# --- Optional providers (app degrades gracefully without these) ---
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=shiftcall-customers
MISTRAL_API_KEY=
OPENAI_API_KEY=
